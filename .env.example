OIMS_HOST=0.0.0.0
OIMS_PORT=3010
OIMS_SECRET_KEY=change-me
OIMS_ADMIN_USERNAME=admin
OIMS_ADMIN_PASSWORD=change-me
# For local testing, keep localhost. For a deployed LAN setup, replace this with the
# actual broker hostname of the OIMS server machine.
OIMS_BROKER_HOSTNAME=localhost
OIMS_BROKER_PORT=1883
OIMS_DATABASE_URL=
# Add the production web origin of your OIMS server when deploying on a LAN hostname.
OIMS_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost,http://127.0.0.1
OIMS_BOOTSTRAP_TOKEN=learning-factory-bootstrap
OIMS_STATION_HEARTBEAT_TIMEOUT_SECONDS=45
